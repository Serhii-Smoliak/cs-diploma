generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SupportTicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum SupportTicketCloseReason {
  ANSWERED
  DECLINED
  CUSTOM
}

enum NotificationType {
  SUPPORT_REPLY
  SYSTEM
  NEWS
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  isBlocked    Boolean  @default(false) @map("is_blocked")
  blockedAt    DateTime? @map("blocked_at")
  blockedReason String? @map("blocked_reason")
  xp           Int      @default(0)
  rank         String   @default("Script Kiddie")
  stealth      Int      @default(100)
  avatarUrl        String?  @map("avatar_url")
  preferredLocale  String?  @map("preferred_locale")
  createdAt        DateTime @default(now()) @map("created_at")

  progress         UserProgress[]
  stats            UserStats?
  mitreTechniques  UserMitreTechnique[]
  supportTickets   SupportTicket[]
  supportMessages  SupportMessage[]
  notifications    Notification[]
  newsPosts        NewsPost[]

  @@map("users")
}

model SupportTicket {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  subject   String
  message   String              @db.Text
  status          SupportTicketStatus       @default(OPEN)
  closedAt        DateTime?                 @map("closed_at")
  closeReason     SupportTicketCloseReason? @map("close_reason")
  closeReasonText String?                   @map("close_reason_text") @db.Text
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  authorId    String   @map("author_id")
  body        String   @db.Text
  isStaffReply Boolean @default(false) @map("is_staff_reply")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([ticketId])
  @@map("support_messages")
}

model Notification {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  type             NotificationType
  title            String
  body             String           @db.Text
  link             String?
  isRead           Boolean          @default(false) @map("is_read")
  supportMessageId String?          @unique @map("support_message_id")
  newsPostId       String?          @map("news_post_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  supportMessage SupportMessage? @relation(fields: [supportMessageId], references: [id], onDelete: Cascade)
  newsPost       NewsPost?       @relation(fields: [newsPostId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([newsPostId])
  @@map("notifications")
}

model NewsPost {
  id          String    @id @default(uuid())
  titleUk     String    @map("title_uk")
  titleEn     String    @map("title_en")
  bodyUk      String    @db.Text @map("body_uk")
  bodyEn      String    @db.Text @map("body_en")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  authorId    String    @map("author_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([isPublished, publishedAt])
  @@map("news_posts")
}

model Mission {
  id              String   @id
  name            String
  description     String?
  difficulty      String
  orderIndex      Int      @map("order_index")
  mitreTechniques Json     @map("mitre_techniques")
  createdAt       DateTime @default(now()) @map("created_at")

  levels                  Level[]
  mitreTechniquesRelation MissionMitreTechnique[]

  @@map("missions")
}

model Level {
  id         String   @id
  missionId  String   @map("mission_id")
  levelId    String   @map("level_id")
  mitreId    String?  @map("mitre_id")
  title      String
  orderIndex Int      @map("order_index")
  taskType   String   @map("task_type")
  dialogue   Json
  workArea   Json     @map("work_area")
  validation Json
  rewards    Json
  hints      Json
  createdAt  DateTime @default(now()) @map("created_at")

  mission        Mission         @relation(fields: [missionId], references: [id])
  mitreTechnique MitreTechnique? @relation(fields: [mitreId], references: [id])

  @@index([mitreId])
  @@map("levels")
}

model UserProgress {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  levelId     String    @map("level_id")
  completed   Boolean   @default(false)
  attempts    Int       @default(0)
  lastAttempt DateTime? @map("last_attempt")
  lastAnswer  String?   @map("last_answer")
  bestScore   Int?      @map("best_score")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId])
  @@index([userId])
  @@index([levelId])
  @@map("user_progress")
}

model UserStats {
  userId              String   @id @map("user_id")
  totalXp             Int      @default(0) @map("total_xp")
  rank                String   @default("Script Kiddie")
  stealth             Int      @default(100)
  completedLevels     Int      @default(0) @map("completed_levels")
  lastStealthUpdateAt DateTime @default(now()) @map("last_stealth_update_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model UserMitreTechnique {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  mitreId     String   @map("mitre_id")
  completedAt DateTime @default(now()) @map("completed_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  technique MitreTechnique? @relation(fields: [mitreId], references: [id])

  @@unique([userId, mitreId])
  @@index([userId])
  @@map("user_mitre_techniques")
}

model MitreTechnique {
  id                  String   @id
  name                String
  description         String?
  tactic              String
  url                 String?
  platforms           Json?    @default("[]")
  dataSources         Json?    @default("[]")
  defenseBypassed     Json?    @default("[]")
  permissionsRequired Json?    @default("[]")
  examples            Json?    @default("[]")
  mitigation          Json?    @default("[]")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  userTechniques UserMitreTechnique[]
  levels         Level[]
  missions       MissionMitreTechnique[]

  @@index([tactic])
  @@map("mitre_techniques")
}

model MissionMitreTechnique {
  id        Int      @id @default(autoincrement())
  missionId String   @map("mission_id")
  mitreId   String   @map("mitre_id")
  createdAt DateTime @default(now()) @map("created_at")

  mission   Mission        @relation(fields: [missionId], references: [id], onDelete: Cascade)
  technique MitreTechnique @relation(fields: [mitreId], references: [id], onDelete: Cascade)

  @@unique([missionId, mitreId])
  @@index([missionId])
  @@index([mitreId])
  @@map("mission_mitre_techniques")
}

model Language {
  code      String   @id
  name      String
  flag      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("languages")
}

model Translation {
  id        Int      @id @default(autoincrement())
  key       String
  locale    String   @default("uk")
  value     String   @db.Text
  namespace String   @default("common")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([key, locale, namespace])
  @@index([locale])
  @@index([namespace])
  @@map("translations")
}
