{
  "name": "@cybertactics/client",
  "version": "0.1.0",
  "description": "CyberTactics Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"index.html\" \"vite.config.ts\" \"vitest.config.ts\" \"eslint.config.js\" \"postcss.config.js\" \"tailwind.config.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"index.html\" \"vite.config.ts\" \"vitest.config.ts\" \"eslint.config.js\" \"postcss.config.js\" \"tailwind.config.js\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cybertactics/shared": "file:../shared",
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-i18next": "^16.5.0",
    "react-router-dom": "^7.1.3",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
